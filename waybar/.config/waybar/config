{
  "layer": "top",
  "position": "top",
  "height": 40,
  "margin-top": 8,
  "margin-left": 12,
  "margin-right": 12,

  "modules-left": [
    "hyprland/workspaces",
    "custom/separator"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "tray",
    "network",
    "pulseaudio"
  ],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "persistent-workspaces": {
      "*": 5
    }
  },

  "clock": {
    "format": "{:%H:%M:%S}",
    "interval": 1,
    "format-alt": "{:%A, %d %B %Y}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "format": {
        "today": "<span color='#f38ba8'><b>{}</b></span>"
      }
    }
  },

  "network": {
    "format-wifi": "󰤨  {signalStrength}%",
    "format-ethernet": "󰈀  Connected",
    "format-disconnected": "󰤭  Offline",
    "tooltip-format-wifi": "{essid}",
    "on-click": "kitty -e nmtui"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "󰝟  Muted",
    "format-icons": {
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pavucontrol"
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8,
    "icon-theme": "Papirus-Dark",
    "show-passive-items": true,
    "reverse-direction": false
  },

  "custom/separator": {
    "format": "",
    "tooltip": false
  }
}
