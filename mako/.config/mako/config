# Mako notification daemon configuration
# Integrates with Wallust for theming

# Include wallust colors
include=~/.cache/wallust/colors-mako

# Appearance
font=sans-serif 11
width=350
height=150
margin=10
padding=15
border-size=2
border-radius=8
icons=1
max-icon-size=48
icon-path=/usr/share/icons/Papirus-Dark

# Position
anchor=top-right
layer=overlay

# Behavior
default-timeout=5000
ignore-timeout=0
max-visible=3
sort=-time

# Grouping
group-by=app-name

# Styling
markup=1
actions=1
format=<b>%s</b>\n%b
